@model TechMove_Logistics_Application.Models.Client

@{
    ViewData["Title"] = "Client Details";
}

<div class="container py-5">

    <!-- BACK BUTTON -->
    <div class="mb-4">

        <a asp-action="Index"
           class="btn btn-outline-secondary rounded-3 shadow-sm">

            ← Back to Clients

        </a>

    </div>

    <!-- DETAILS CARD -->
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <!-- HEADER -->
        <div class="bg-primary text-white p-4">

            <h1 class="fw-bold mb-1">
                Client Details
            </h1>

            <p class="mb-0 fs-5">
                View complete client information.
            </p>

        </div>

        <!-- BODY -->
        <div class="card-body p-5">

            <div class="row g-4">

                <!-- CLIENT NAME -->
                <div class="col-md-4">

                    <div class="card border-0 bg-light shadow-sm rounded-4 h-100">

                        <div class="card-body">

                            <small class="text-muted d-block mb-2">
                                Client Name
                            </small>

                            <h3 class="fw-bold text-primary mb-0">
                                @Model.Name
                            </h3>

                        </div>

                    </div>

                </div>

                <!-- CONTACT DETAILS -->
                <div class="col-md-4">

                    <div class="card border-0 bg-light shadow-sm rounded-4 h-100">

                        <div class="card-body">

                            <small class="text-muted d-block mb-2">
                                Contact Details
                            </small>

                            <h5 class="fw-semibold mb-0">
                                @Model.ContactDetails
                            </h5>

                        </div>

                    </div>

                </div>

                <!-- REGION -->
                <div class="col-md-4">

                    <div class="card border-0 bg-light shadow-sm rounded-4 h-100">

                        <div class="card-body">

                            <small class="text-muted d-block mb-2">
                                Region
                            </small>

                            <span class="badge bg-success px-4 py-2 fs-6 rounded-pill">

                                @Model.Region

                            </span>

                        </div>

                    </div>

                </div>

            </div>

            <!-- ACTION BUTTONS -->
            <div class="mt-5 d-flex gap-3">

                <a asp-action="Edit"
                   asp-route-id="@Model?.Id"
                   class="btn btn-primary btn-lg px-5 rounded-3 shadow-sm">

                    Edit Client

                </a>

                <a asp-action="Delete"
                   asp-route-id="@Model?.Id"
                   class="btn btn-danger btn-lg px-5 rounded-3 shadow-sm">

                    Delete Client

                </a>

            </div>

        </div>

    </div>

</div>