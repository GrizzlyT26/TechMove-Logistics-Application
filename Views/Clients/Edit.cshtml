@model TechMove_Logistics_Application.Models.Client

@{
    ViewData["Title"] = "Edit Client";
}

<div class="container py-5">

    <!-- BACK BUTTON -->
    <div class="mb-4">

        <a asp-action="Index"
           class="btn btn-outline-secondary rounded-3 shadow-sm">

            ← Back to Clients

        </a>

    </div>

    <!-- EDIT CARD -->
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <!-- HEADER -->
        <div class="bg-warning text-dark p-4">

            <h1 class="fw-bold mb-1">
                Edit Client
            </h1>

            <p class="mb-0 fs-5">
                Update client information and regional details.
            </p>

        </div>

        <!-- BODY -->
        <div class="card-body p-5">

            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger rounded-3">
                </div>

                <input type="hidden" asp-for="Id" />

                <div class="row g-4">

                    <!-- CLIENT NAME -->
                    <div class="col-md-6">

                        <label asp-for="Name"
                               class="form-label fw-semibold">
                        </label>

                        <input asp-for="Name"
                               class="form-control form-control-lg rounded-3 shadow-sm" />

                        <span asp-validation-for="Name"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- CONTACT DETAILS -->
                    <div class="col-md-6">

                        <label asp-for="ContactDetails"
                               class="form-label fw-semibold">
                        </label>

                        <input asp-for="ContactDetails"
                               class="form-control form-control-lg rounded-3 shadow-sm" />

                        <span asp-validation-for="ContactDetails"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- REGION -->
                    <div class="col-md-6">

                        <label asp-for="Region"
                               class="form-label fw-semibold">
                        </label>

                        <select asp-for="Region"
                                class="form-select form-select-lg rounded-3 shadow-sm">

                            <option value="">-- Select Region --</option>

                            <option>Africa</option>
                            <option>Europe</option>
                            <option>Asia</option>
                            <option>North America</option>
                            <option>South America</option>
                            <option>Middle East</option>
                            <option>Australia</option>

                        </select>

                        <span asp-validation-for="Region"
                              class="text-danger">
                        </span>

                    </div>

                </div>

                <!-- ACTION BUTTONS -->
                <div class="mt-5 d-flex gap-3">

                    <input type="submit"
                           value="Save Changes"
                           class="btn btn-warning btn-lg px-5 rounded-3 shadow-sm" />

                    <a asp-action="Details"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-dark btn-lg px-5 rounded-3">

                        Cancel

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}