@model TechMove_Logistics_Application.Models.Client

@{
    ViewData["Title"] = "Create Client";
}

<div class="container py-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="fw-bold display-5">
                Create Client
            </h1>

            <p class="text-muted">
                Add a new logistics client to the Global Logistics Management System.
            </p>
        </div>

        <a asp-controller="Home"
           asp-action="Index"
           class="btn btn-dark btn-lg shadow-sm rounded-3">

            ← Dashboard

        </a>

    </div>

    <!-- Main Card -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-5">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger">
                </div>

                <!-- Name -->
                <div class="mb-4">

                    <label asp-for="Name"
                           class="form-label fw-semibold fs-5">
                        Client Name
                    </label>

                    <input asp-for="Name"
                           class="form-control form-control-lg rounded-3"
                           placeholder="Enter client/company name" />

                    <span asp-validation-for="Name"
                          class="text-danger"></span>

                </div>

                <!-- Contact -->
                <div class="mb-4">

                    <label asp-for="ContactDetails"
                           class="form-label fw-semibold fs-5">
                        Contact Details
                    </label>

                    <input asp-for="ContactDetails"
                           class="form-control form-control-lg rounded-3"
                           placeholder="Email or phone number" />

                    <span asp-validation-for="ContactDetails"
                          class="text-danger"></span>

                </div>

                <!-- Region -->
                <div class="mb-4">

                    <label asp-for="Region"
                           class="form-label fw-semibold fs-5">
                        Region
                    </label>

                    <select asp-for="Region"
                            class="form-select form-select-lg rounded-3">

                        <option value="">
                            -- Select Region --
                        </option>

                        <option>Africa</option>
                        <option>Europe</option>
                        <option>Asia</option>
                        <option>North America</option>
                        <option>South America</option>
                        <option>Middle East</option>
                        <option>Australia</option>

                    </select>

                    <span asp-validation-for="Region"
                          class="text-danger"></span>

                </div>

                <!-- Buttons -->
                <div class="d-flex gap-3 mt-5">

                    <button type="submit"
                            class="btn btn-primary btn-lg px-5 shadow rounded-3">

                        Create Client

                    </button>

                    <a asp-action="Index"
                       class="btn btn-outline-secondary btn-lg rounded-3">

                        View Clients

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}