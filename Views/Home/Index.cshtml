@model TechMove_Logistics_Application.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid py-4 px-4">

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-5">

        <div>
            <h1 class="fw-bold display-5">
                Global Logistics Dashboard
            </h1>

            <p class="text-muted fs-5">
                Monitor contracts, clients, and logistics operations in real time.
            </p>
        </div>

        <div>
            <span class="badge bg-success fs-6 p-3 shadow-sm">
                System Online
            </span>
        </div>

    </div>

    <!-- KPI CARDS -->
    <div class="row g-4 mb-5">

        <!-- CLIENTS -->
        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-lg rounded-4 bg-primary text-white h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <h6 class="text-uppercase">
                                Total Clients
                            </h6>

                            <h1 class="fw-bold display-5">
                                @Model.TotalClients
                            </h1>
                        </div>

                        <div class="fs-1">
                            👥
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- ACTIVE CONTRACTS -->
        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-lg rounded-4 bg-success text-white h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <h6 class="text-uppercase">
                                Active Contracts
                            </h6>

                            <h1 class="fw-bold display-5">
                                @Model.ActiveContracts
                            </h1>
                        </div>

                        <div class="fs-1">
                            📄
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- EXPIRED -->
        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-lg rounded-4 bg-danger text-white h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <h6 class="text-uppercase">
                                Expired Contracts
                            </h6>

                            <h1 class="fw-bold display-5">
                                @Model.ExpiredContracts
                            </h1>
                        </div>

                        <div class="fs-1">
                            ⚠️
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- SERVICE REQUESTS -->
        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-lg rounded-4 bg-dark text-white h-100">

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <h6 class="text-uppercase">
                                Service Requests
                            </h6>

                            <h1 class="fw-bold display-5">
                                @Model.TotalServiceRequests
                            </h1>
                        </div>

                        <div class="fs-1">
                            🚚
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- QUICK ACTIONS -->
    <div class="card border-0 shadow-lg rounded-4 mb-5">

        <div class="card-body p-4">

            <h3 class="fw-bold mb-4">
                Quick Actions
            </h3>

            <div class="row g-3">

                <div class="col-md-4">

                    <a asp-controller="Clients"
                       asp-action="Create"
                       class="btn btn-primary btn-lg w-100 p-4 rounded-4 shadow">

                        + New Client

                    </a>

                </div>

                <div class="col-md-4">

                    <a asp-controller="Contracts"
                       asp-action="Create"
                       class="btn btn-success btn-lg w-100 p-4 rounded-4 shadow">

                        + New Contract

                    </a>

                </div>

                <div class="col-md-4">

                    <a asp-controller="ServiceRequests"
                       asp-action="Create"
                       class="btn btn-dark btn-lg w-100 p-4 rounded-4 shadow">

                        + New Service Request

                    </a>

                </div>

            </div>

        </div>

    </div>

    <!-- SYSTEM OVERVIEW -->
    <div class="row g-4">

        <!-- SYSTEM STATUS -->
        <div class="col-lg-6">

            <div class="card border-0 shadow-lg rounded-4 h-100">

                <div class="card-body p-4">

                    <h3 class="fw-bold mb-4">
                        System Status
                    </h3>

                    <div class="mb-3 d-flex justify-content-between">
                        <span>Database Connection</span>
                        <span class="badge bg-success">
                            Online
                        </span>
                    </div>

                    <div class="mb-3 d-flex justify-content-between">
                        <span>File Storage</span>
                        <span class="badge bg-success">
                            Active
                        </span>
                    </div>

                    <div class="mb-3 d-flex justify-content-between">
                        <span>Exchange Rate API</span>
                        <span class="badge bg-success">
                            Connected
                        </span>
                    </div>

                </div>

            </div>

        </div>

        <!-- BUSINESS SUMMARY -->
        <div class="col-lg-6">

            <div class="card border-0 shadow-lg rounded-4 h-100">

                <div class="card-body p-4">

                    <h3 class="fw-bold mb-4">
                        Business Summary
                    </h3>

                    <p class="text-muted fs-5">

                        TechMove Logistics manages international freight
                        contracts, client operations, and logistics
                        workflows through a centralized enterprise platform.

                    </p>

                    <div class="mt-4">

                        <span class="badge bg-primary p-3 me-2">
                            Logistics
                        </span>

                        <span class="badge bg-success p-3 me-2">
                            Contracts
                        </span>

                        <span class="badge bg-dark p-3">
                            Enterprise
                        </span>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>