<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - TechMove_Logistics_Application</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/TechMove_Logistics_Application.styles.css"
          asp-append-version="true" />
</head>

<body>

    <!-- HEADER -->
    <header>

        <!-- MODERN NAVBAR -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3">

            <div class="container-fluid px-4">

                <!-- LOGO -->
                <a class="navbar-brand fw-bold fs-3 text-white"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">

                    TechMove Logistics

                </a>

                <!-- MOBILE MENU BUTTON -->
                <button class="navbar-toggler border-0 shadow-none"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <!-- NAVIGATION LINKS -->
                <div class="collapse navbar-collapse"
                     id="mainNavbar">

                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">

                        <li class="nav-item">

                            <a class="nav-link nav-modern px-3"
                               asp-controller="Home"
                               asp-action="Index">

                                Dashboard

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link nav-modern px-3"
                               asp-controller="Clients"
                               asp-action="Index">

                                Clients

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link nav-modern px-3"
                               asp-controller="Contracts"
                               asp-action="Index">

                                Contracts

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link nav-modern px-3"
                               asp-controller="ServiceRequests"
                               asp-action="Index">

                                Service Requests

                            </a>

                        </li>

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <!-- MAIN CONTENT -->
    <div class="container">

        <!-- SUCCESS MESSAGE -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mt-4 shadow-sm rounded-3"
                 role="alert">

                @TempData["SuccessMessage"]

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert">
                </button>

            </div>
        }

        <!-- PAGE CONTENT -->
        <main role="main" class="pb-3">

            @RenderBody()

        </main>

    </div>

    <!-- FOOTER -->
    <footer class="bg-dark text-light mt-5 pt-5 pb-4 shadow-lg">

        <div class="container">

            <div class="row align-items-start gy-4">

                <!-- COMPANY INFO -->
                <div class="col-lg-6 col-md-12">

                    <h3 class="fw-bold text-white mb-3">
                        TechMove Logistics
                    </h3>

                    <p class="text-light-emphasis fs-6 mb-0"
                       style="max-width: 500px; line-height: 1.8;">

                        Smart global logistics management platform designed
                        to streamline client operations, contract management,
                        and service request workflows efficiently and professionally.

                    </p>

                </div>

                <!-- QUICK LINKS -->
                <div class="col-lg-3 col-md-6">

                    <h5 class="fw-semibold text-white mb-3">
                        Quick Links
                    </h5>

                    <ul class="list-unstyled">

                        <li class="mb-2">

                            <a asp-controller="Home"
                               asp-action="Index"
                               class="text-decoration-none text-light footer-link">

                                Dashboard

                            </a>

                        </li>

                        <li class="mb-2">

                            <a asp-controller="Clients"
                               asp-action="Index"
                               class="text-decoration-none text-light footer-link">

                                Clients

                            </a>

                        </li>

                        <li class="mb-2">

                            <a asp-controller="Contracts"
                               asp-action="Index"
                               class="text-decoration-none text-light footer-link">

                                Contracts

                            </a>

                        </li>

                        <li class="mb-2">

                            <a asp-controller="ServiceRequests"
                               asp-action="Index"
                               class="text-decoration-none text-light footer-link">

                                Service Requests

                            </a>

                        </li>

                    </ul>

                </div>

            </div>

            <!-- DIVIDER -->
            <hr class="border-secondary my-4" />

            <!-- FOOTER BOTTOM -->
            <div class="d-flex flex-column flex-md-row
                        justify-content-between
                        align-items-center">

                <p class="mb-2 mb-md-0 text-light-emphasis text-center text-md-start">

                    © 2026 TechMove Logistics Application |
                    Developed by Kamogelo Mafuna

                </p>

            </div>

        </div>

    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>