@model TechMove_Logistics_Application.Models.ServiceRequest

@{
    ViewData["Title"] = "Create Service Request";
}

<div class="container py-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold display-5">
                Create Service Request
            </h1>

            <p class="text-muted fs-5">
                Create and manage logistics service operations.
            </p>

        </div>

        <a asp-controller="Contracts"
           asp-action="Index"
           class="btn btn-dark btn-lg shadow-sm rounded-3">

            ← Back to Contracts

        </a>

    </div>

    <!-- MAIN CARD -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-5">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger">
                </div>

                <!-- CONTRACT -->
                <div class="mb-4">

                    <label asp-for="ContractId"
                           class="form-label fw-semibold fs-5">

                        Contract

                    </label>

                    <select asp-for="ContractId"
                            class="form-select form-select-lg rounded-3"
                            asp-items="ViewBag.ContractId">

                        <option value="">
                            -- Select Contract --
                        </option>

                    </select>

                    <span asp-validation-for="ContractId"
                          class="text-danger"></span>

                </div>

                <!-- DESCRIPTION -->
                <div class="mb-4">

                    <label asp-for="Description"
                           class="form-label fw-semibold fs-5">

                        Request Description

                    </label>

                    <textarea asp-for="Description"
                              class="form-control form-control-lg rounded-3"
                              rows="4"
                              placeholder="Describe the logistics request...">
                    </textarea>

                    <span asp-validation-for="Description"
                          class="text-danger"></span>

                </div>

                <!-- COST USD -->
                <div class="mb-4">

                    <label asp-for="CostUSD"
                           class="form-label fw-semibold fs-5">

                        Cost (USD)

                    </label>

                    <input asp-for="CostUSD"
                           class="form-control form-control-lg rounded-3"
                           placeholder="Enter amount in USD" />

                    <span asp-validation-for="CostUSD"
                          class="text-danger"></span>

                </div>

                <!-- COST ZAR -->
                <div class="mb-4">

                    <label asp-for="CostZAR"
                           class="form-label fw-semibold fs-5">

                        Cost (ZAR)

                    </label>

                    <input asp-for="CostZAR"
                           class="form-control form-control-lg rounded-3"
                           placeholder="Auto-calculated ZAR amount" />

                    <span asp-validation-for="CostZAR"
                          class="text-danger"></span>

                </div>

                <!-- STATUS -->
                <div class="mb-4">

                    <label asp-for="Status"
                           class="form-label fw-semibold fs-5">

                        Request Status

                    </label>

                    <select asp-for="Status"
                            class="form-select form-select-lg rounded-3">

                        <option value="">
                            -- Select Status --
                        </option>

                        <option>Pending</option>
                        <option>Active</option>
                        <option>Completed</option>
                        <option>Cancelled</option>

                    </select>

                    <span asp-validation-for="Status"
                          class="text-danger"></span>

                </div>

                <!-- BUTTONS -->
                <div class="d-flex gap-3 mt-5">

                    <button type="submit"
                            class="btn btn-primary btn-lg px-5 shadow rounded-3">

                        Create Request

                    </button>

                    <a asp-action="Index"
                       class="btn btn-outline-secondary btn-lg rounded-3">

                        View Requests

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}