@model IEnumerable<TechMove_Logistics_Application.Models.ServiceRequest>

@{
    ViewData["Title"] = "Service Requests";
}

<div class="container py-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold display-5">
                Service Requests
            </h1>

            <p class="text-muted fs-5">
                Manage logistics operations and international service workflows.
            </p>

        </div>

        <a asp-action="Create"
           class="btn btn-primary btn-lg shadow rounded-3">

            + New Service Request

        </a>

    </div>

    <!-- CARD -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-4">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">

                        <tr>

                            <th>
                                Contract
                            </th>

                            <th>
                                Description
                            </th>

                            <th>
                                Cost (USD)
                            </th>

                            <th>
                                Cost (ZAR)
                            </th>

                            <th>
                                Status
                            </th>

                            <th class="text-center">
                                Actions
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td class="fw-semibold">
                                    #@item.ContractId
                                </td>

                                <td style="max-width: 400px;">
                                    @item.Description
                                </td>

                                <td>
                                    $@item.CostUSD
                                </td>

                                <td>
                                    R @item.CostZAR
                                </td>

                                <td>

                                    @if (item.Status == "Active")
                                    {
                                        <span class="badge bg-success p-2">
                                            Active
                                        </span>
                                    }
                                    else if (item.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark p-2">
                                            Pending
                                        </span>
                                    }
                                    else if (item.Status == "Completed")
                                    {
                                        <span class="badge bg-primary p-2">
                                            Completed
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger p-2">
                                            Cancelled
                                        </span>
                                    }

                                </td>

                                <td class="text-center">

                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary me-1">

                                        Edit

                                    </a>

                                    <a asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-dark me-1">

                                        Details

                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger">

                                        Delete

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>