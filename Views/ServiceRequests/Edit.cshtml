@model TechMove_Logistics_Application.Models.ServiceRequest

@{
    ViewData["Title"] = "Edit Service Request";
}

<div class="container py-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold display-5 text-primary">
                Edit Service Request
            </h1>

            <p class="text-muted fs-5">
                Update and manage logistics service request details.
            </p>

        </div>

        <a asp-action="Index"
           class="btn btn-dark btn-lg rounded-3 shadow-sm">

            ← Back to Requests

        </a>

    </div>

    <!-- CARD -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-5">

            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger rounded-3">
                </div>

                <input type="hidden"
                       asp-for="Id" />

                <!-- CONTRACT -->
                <div class="mb-4">

                    <label asp-for="ContractId"
                           class="form-label fw-semibold fs-5">
                        Contract
                    </label>

                    <select asp-for="ContractId"
                            class="form-select form-select-lg rounded-3"
                            asp-items="ViewBag.ContractId">
                    </select>

                    <span asp-validation-for="ContractId"
                          class="text-danger">
                    </span>

                </div>

                <!-- DESCRIPTION -->
                <div class="mb-4">

                    <label asp-for="Description"
                           class="form-label fw-semibold fs-5">
                        Service Description
                    </label>

                    <textarea asp-for="Description"
                              class="form-control rounded-3"
                              rows="5"
                              placeholder="Enter detailed service request description">
                    </textarea>

                    <span asp-validation-for="Description"
                          class="text-danger">
                    </span>

                </div>

                <!-- COSTS -->
                <div class="row">

                    <div class="col-md-6 mb-4">

                        <label asp-for="CostUSD"
                               class="form-label fw-semibold fs-5">
                            Cost (USD)
                        </label>

                        <div class="input-group input-group-lg">

                            <span class="input-group-text">
                                $
                            </span>

                            <input asp-for="CostUSD"
                                   class="form-control rounded-end" />

                        </div>

                        <span asp-validation-for="CostUSD"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="col-md-6 mb-4">

                        <label asp-for="CostZAR"
                               class="form-label fw-semibold fs-5">
                            Cost (ZAR)
                        </label>

                        <div class="input-group input-group-lg">

                            <span class="input-group-text">
                                R
                            </span>

                            <input asp-for="CostZAR"
                                   class="form-control rounded-end" />

                        </div>

                        <span asp-validation-for="CostZAR"
                              class="text-danger">
                        </span>

                    </div>

                </div>

                <!-- STATUS -->
                <div class="mb-5">

                    <label asp-for="Status"
                           class="form-label fw-semibold fs-5">
                        Request Status
                    </label>

                    <select asp-for="Status"
                            class="form-select form-select-lg rounded-3">

                        <option value="">-- Select Status --</option>

                        <option>Active</option>
                        <option>Pending</option>
                        <option>Completed</option>
                        <option>Cancelled</option>

                    </select>

                    <span asp-validation-for="Status"
                          class="text-danger">
                    </span>

                </div>

                <!-- BUTTONS -->
                <div class="d-flex gap-3">

                    <button type="submit"
                            class="btn btn-primary btn-lg px-5 shadow rounded-3">

                        Save Changes

                    </button>

                    <a asp-action="Index"
                       class="btn btn-outline-secondary btn-lg rounded-3">

                        Cancel

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}