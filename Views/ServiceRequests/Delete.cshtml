@model TechMove_Logistics_Application.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<div class="container py-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold display-5 text-danger">
                Delete Service Request
            </h1>

            <p class="text-muted fs-5">
                Confirm removal of this logistics service request.
            </p>

        </div>

        <a asp-action="Index"
           class="btn btn-dark btn-lg rounded-3 shadow-sm">

            ← Back to Requests

        </a>

    </div>

    <!-- WARNING ALERT -->
    <div class="alert alert-danger shadow-sm rounded-4 p-4 mb-4">

        <h4 class="fw-bold mb-2">
            Warning
        </h4>

        <p class="mb-0">
            You are about to permanently delete this service request.
            This action cannot be undone.
        </p>

    </div>

    <!-- DETAILS CARD -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-5">

            <div class="row mb-4">

                <div class="col-md-3 fw-bold fs-5">
                    Contract ID
                </div>

                <div class="col-md-9 fs-5">
                    #@Model.ContractId
                </div>

            </div>

            <div class="row mb-4">

                <div class="col-md-3 fw-bold fs-5">
                    Description
                </div>

                <div class="col-md-9 fs-5 text-muted">
                    @Model.Description
                </div>

            </div>

            <div class="row mb-4">

                <div class="col-md-3 fw-bold fs-5">
                    Cost (USD)
                </div>

                <div class="col-md-9 fs-5">
                    $@Model.CostUSD
                </div>

            </div>

            <div class="row mb-4">

                <div class="col-md-3 fw-bold fs-5">
                    Cost (ZAR)
                </div>

                <div class="col-md-9 fs-5">
                    R @Model.CostZAR
                </div>

            </div>

            <div class="row mb-5">

                <div class="col-md-3 fw-bold fs-5">
                    Status
                </div>

                <div class="col-md-9">

                    @if (Model.Status == "Active")
                    {
                        <span class="badge bg-success p-3 fs-6">
                            Active
                        </span>
                    }
                    else if (Model.Status == "Pending")
                    {
                        <span class="badge bg-warning text-dark p-3 fs-6">
                            Pending
                        </span>
                    }
                    else if (Model.Status == "Completed")
                    {
                        <span class="badge bg-primary p-3 fs-6">
                            Completed
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger p-3 fs-6">
                            Cancelled
                        </span>
                    }

                </div>

            </div>

            <!-- DELETE FORM -->
            <form asp-action="Delete">

                <input type="hidden"
                       asp-for="Id" />

                <div class="d-flex gap-3">

                    <button type="submit"
                            class="btn btn-danger btn-lg px-5 shadow rounded-3">

                        Delete Request

                    </button>

                    <a asp-action="Index"
                       class="btn btn-outline-secondary btn-lg rounded-3">

                        Cancel

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>