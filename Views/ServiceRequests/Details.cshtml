@model TechMove_Logistics_Application.Models.ServiceRequest

@{
    ViewData["Title"] = "Service Request Details";
}

<div class="container py-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold display-5 text-primary">
                Service Request Details
            </h1>

            <p class="text-muted fs-5">
                Detailed overview of the selected logistics service request.
            </p>

        </div>

        <a asp-action="Index"
           class="btn btn-dark btn-lg rounded-3 shadow-sm">

            ← Back to Requests

        </a>

    </div>

    <!-- DETAILS CARD -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-5">

            <div class="row mb-4">

                <div class="col-md-4">

                    <div class="bg-light rounded-4 p-4 shadow-sm h-100">

                        <h6 class="text-muted text-uppercase">
                            Contract ID
                        </h6>

                        <h3 class="fw-bold text-primary">
                            #@Model.Contract.Id
                        </h3>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="bg-light rounded-4 p-4 shadow-sm h-100">

                        <h6 class="text-muted text-uppercase">
                            Cost (USD)
                        </h6>

                        <h3 class="fw-bold text-success">
                            $@Model.CostUSD
                        </h3>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="bg-light rounded-4 p-4 shadow-sm h-100">

                        <h6 class="text-muted text-uppercase">
                            Cost (ZAR)
                        </h6>

                        <h3 class="fw-bold text-dark">
                            R @Model.CostZAR
                        </h3>

                    </div>

                </div>

            </div>

            <!-- DESCRIPTION -->
            <div class="mb-5">

                <h5 class="fw-bold text-primary mb-3">
                    Service Description
                </h5>

                <div class="bg-light rounded-4 p-4 shadow-sm">

                    <p class="mb-0 fs-5 text-dark">

                        @Model.Description

                    </p>

                </div>

            </div>

            <!-- STATUS -->
            <div class="mb-5">

                <h5 class="fw-bold text-primary mb-3">
                    Request Status
                </h5>

                <span class="badge bg-success fs-6 px-4 py-3 rounded-pill shadow-sm">

                    @Model.Status

                </span>

            </div>

            <!-- ACTION BUTTONS -->
            <div class="d-flex gap-3">

                <a asp-action="Edit"
                   asp-route-id="@Model?.Id"
                   class="btn btn-primary btn-lg px-5 shadow rounded-3">

                    Edit Request

                </a>

                <a asp-action="Delete"
                   asp-route-id="@Model?.Id"
                   class="btn btn-danger btn-lg px-5 shadow rounded-3">

                    Delete Request

                </a>

            </div>

        </div>

    </div>

</div>