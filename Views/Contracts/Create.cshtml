@model TechMove_Logistics_Application.Models.Contract

@{
    ViewData["Title"] = "Create Contract";
}

<div class="container py-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold display-5">
                Create Contract
            </h1>

            <p class="text-muted fs-5">
                Register and manage logistics service agreements.
            </p>

        </div>

        <a asp-controller="Clients"
           asp-action="Index"
           class="btn btn-dark btn-lg shadow-sm rounded-3">

            ← Back to Clients

        </a>

    </div>

    <!-- MAIN CARD View -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-5">

            <form asp-action="Create"
                  enctype="multipart/form-data">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger">
                </div>

                <!-- CLIENT -->
                <div class="mb-4">

                    <label asp-for="ClientId"
                           class="form-label fw-semibold fs-5">

                        Client

                    </label>

                    <select asp-for="ClientId"
                            class="form-select form-select-lg rounded-3"
                            asp-items="ViewBag.ClientId">

                        <option value="">
                            -- Select Client --
                        </option>

                    </select>

                    <span asp-validation-for="ClientId"
                          class="text-danger"></span>

                </div>

                <!-- START DATE -->
                <div class="mb-4">

                    <label asp-for="StartDate"
                           class="form-label fw-semibold fs-5">

                        Contract Start Date

                    </label>

                    <input asp-for="StartDate"
                           type="datetime-local"
                           class="form-control form-control-lg rounded-3" />

                    <span asp-validation-for="StartDate"
                          class="text-danger"></span>

                </div>

                <!-- END DATE -->
                <div class="mb-4">

                    <label asp-for="EndDate"
                           class="form-label fw-semibold fs-5">

                        Contract End Date

                    </label>

                    <input asp-for="EndDate"
                           type="datetime-local"
                           class="form-control form-control-lg rounded-3" />

                    <span asp-validation-for="EndDate"
                          class="text-danger"></span>

                </div>

                <!-- STATUS -->
                <div class="mb-4">

                    <label asp-for="Status"
                           class="form-label fw-semibold fs-5">

                        Contract Status

                    </label>

                    <select asp-for="Status"
                            class="form-select form-select-lg rounded-3">

                        <option value="">
                            -- Select Status --
                        </option>

                        <option>Draft</option>
                        <option>Active</option>
                        <option>Expired</option>
                        <option>On Hold</option>

                    </select>

                    <span asp-validation-for="Status"
                          class="text-danger"></span>

                </div>

                <!-- SERVICE LEVEL -->
                <div class="mb-4">

                    <label asp-for="ServiceLevel"
                           class="form-label fw-semibold fs-5">

                        Service Level Agreement

                    </label>

                    <select asp-for="ServiceLevel"
                            class="form-select form-select-lg rounded-3">

                        <option value="">
                            -- Select Service Level --
                        </option>

                        <option>Basic</option>
                        <option>Standard</option>
                        <option>Premium</option>
                        <option>Enterprise</option>

                    </select>

                    <span asp-validation-for="ServiceLevel"
                          class="text-danger"></span>

                </div>

                <!-- FILE UPLOAD -->
                <div class="mb-4">

                    <label class="form-label fw-semibold fs-5">

                        Upload Signed Agreement (PDF)

                    </label>

                    <input type="file"
                           name="agreementFile"
                           class="form-control form-control-lg rounded-3" />

                </div>

                <!-- BUTTONS -->
                <div class="d-flex gap-3 mt-5">

                    <button type="submit"
                            class="btn btn-success btn-lg px-5 shadow rounded-3">

                        Create Contract

                    </button>

                    <a asp-action="Index"
                       class="btn btn-outline-secondary btn-lg rounded-3">

                        View Contracts

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}