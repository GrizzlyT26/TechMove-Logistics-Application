@model IEnumerable<TechMove_Logistics_Application.Models.Contract>

@{
    ViewData["Title"] = "Contracts";
}

<div class="container py-5">

    <!-- PAGE HEADER -->
    <div class="d-flex flex-column flex-lg-row
                justify-content-between
                align-items-lg-center
                mb-5">

        <div>

            <h1 class="fw-bold display-5 text-primary mb-2">
                Contracts Management
            </h1>

            <p class="text-muted fs-5 mb-0">
                Manage logistics agreements, service levels,
                and contract lifecycle operations.
            </p>

        </div>

        <div class="mt-4 mt-lg-0">

            <a asp-action="Create"
               class="btn btn-success btn-lg rounded-4 shadow-sm px-4">

                + New Contract

            </a>

        </div>

    </div>

    <!-- SEARCH / FILTER CARD -->
    <div class="card border-0 shadow-lg rounded-4 mb-4">

        <div class="card-body p-4">

            <form method="get">

                <div class="row g-3">

                    <!-- SEARCH -->
                    <div class="col-lg-5">

                        <input type="text"
                               name="searchString"
                               value="@Context.Request.Query["searchString"]"
                               class="form-control form-control-lg rounded-3 border-0 shadow-sm"
                               placeholder="Search by client, status or service level..." />

                    </div>

                    <!-- STATUS FILTER -->
                    <div class="col-lg-3">

                        <select name="statusFilter"
                                class="form-select form-select-lg rounded-3 border-0 shadow-sm">

                            <option value="">
                                All Statuses
                            </option>

                            <option value="Active"
                                    selected="@(Context.Request.Query["statusFilter"] == "Active")">

                                Active

                            </option>

                            <option value="Draft"
                                    selected="@(Context.Request.Query["statusFilter"] == "Draft")">

                                Draft

                            </option>

                            <option value="Expired"
                                    selected="@(Context.Request.Query["statusFilter"] == "Expired")">

                                Expired

                            </option>

                            <option value="On Hold"
                                    selected="@(Context.Request.Query["statusFilter"] == "On Hold")">

                                On Hold

                            </option>

                        </select>

                    </div>

                    <!-- BUTTON -->
                    <div class="col-lg-4">

                        <button type="submit"
                                class="btn btn-dark btn-lg w-100 rounded-3 shadow-sm">

                            Filter Contracts

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>

    <!-- CONTRACTS TABLE -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-dark">

                        <tr>

                            <th class="ps-4">
                                Client
                            </th>

                            <th>
                                Start Date
                            </th>

                            <th>
                                End Date
                            </th>

                            <th>
                                Status
                            </th>

                            <th>
                                Service Level
                            </th>

                            <th>
                                Agreement
                            </th>

                            <th class="text-center pe-4">
                                Actions
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>

                                    <!-- CLIENT -->
                                    <td class="fw-semibold text-primary ps-4">

                                        @(item.Client != null
                                                                        ? item.Client.Name
                                                                        : $"Client #{item.ClientId}")

                            </td>

                                    <!-- START DATE -->
                                    <td>

                                        @item.StartDate.ToShortDateString()

                                    </td>

                                    <!-- END DATE -->
                                    <td>

                                        @item.EndDate.ToShortDateString()

                                    </td>

                                    <!-- STATUS -->
                                    <td>

                                @if (item.Status == "Active")
                                        {
                                            <span class="badge bg-success px-3 py-2 rounded-pill">
                                                Active
                                            </span>
                                        }
                                        else if (item.Status == "Draft")
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">
                                                Draft
                                            </span>
                                        }
                                        else if (item.Status == "Expired")
                                        {
                                            <span class="badge bg-danger px-3 py-2 rounded-pill">
                                                Expired
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary px-3 py-2 rounded-pill">
                                                On Hold
                                            </span>
                                        }

                                    </td>

                                    <!-- SERVICE LEVEL -->
                                    <td>

                                        <span class="badge bg-primary px-3 py-2 rounded-pill">

                                            @item.ServiceLevel

                                        </span>

                                    </td>

                                    <!-- AGREEMENT -->
                                    <td>

                                        @if (!string.IsNullOrEmpty(item.AgreementFilePath))
                                        {
                                            <a href="~/agreements/@item.AgreementFilePath"
                                               target="_blank"
                                               class="btn btn-sm btn-outline-dark rounded-3">

                                                View PDF

                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">
                                                No File
                                            </span>
                                        }

                                    </td>

                                    <!-- ACTIONS -->
                                    <td class="text-center pe-4">

                                        <div class="d-flex justify-content-center gap-2 flex-wrap">

                                            <a asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-primary rounded-3">

                                                Edit

                                            </a>

                                            <a asp-action="Details"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-dark rounded-3">

                                                Details

                                            </a>

                                            <a asp-action="Delete"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-danger rounded-3">

                                                Delete

                                            </a>

                                        </div>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="7"
                                    class="text-center py-5 text-muted fs-5">

                                    No contracts found.

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>